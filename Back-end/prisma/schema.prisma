// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipes   Recipe[]
}

model IngrCategory {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  icon        String?
  ingredients Ingredient[]
}

model Ingredient {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  image String?

  recipes IngredientsInTheRecipe[]

  categoryId Int
  category   IngrCategory @relation(fields: [categoryId], references: [id])
}

model RecipeCategory {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  recipes Recipe[]
}

model Difficulty {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  icon    String?
  recipes Recipe[]
}

model Recipe {
  id          String                   @id @default(uuid())
  name        String
  image       String?
  steps       String[]
  ingredients IngredientsInTheRecipe[]

  categoryId   Int
  category     RecipeCategory @relation(fields: [categoryId], references: [id])
  difficultyId Int
  difficulty   Difficulty     @relation(fields: [difficultyId], references: [id])
  creatorId    String
  creator      User           @relation(fields: [creatorId], references: [id])

  isPublic Boolean @default(false)

  @@unique([name, creatorId])
}

model Measure {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @unique
  abbreviation           String                   @unique
  ingredientsInTheRecipe IngredientsInTheRecipe[]
}

model IngredientsInTheRecipe {
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  qnt          Float
  measureId    Int
  measure      Measure    @relation(fields: [measureId], references: [id])

  @@id([recipeId, ingredientId])
}
